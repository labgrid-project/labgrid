#!/bin/bash

# This is included by all ub-xxx scripts

# Usage
# . lg-env                    (set lab environment variables)
#
# All variables set here are defaults — set them in the calling
# environment first to override (useful for running from a remote
# machine, e.g. via tailscale).

# Hostname and port for the gRPC coordinator
export LG_COORDINATOR=${LG_COORDINATOR:-kea:20408}

# Environment file for the lab
export LG_ENV=${LG_ENV:-/vid/software/devel/ubtest/lab/cfg/kea_env.cfg}

# Location of the U-Boot test hooks
export UB_TEST_HOOKS=${UB_TEST_HOOKS:-/home/sglass/u/test/hooks}

# Make sure only one buildman can run at a time, since it uses all CPUs
export BUILDMAN_PROCESS_LIMIT=${BUILDMAN_PROCESS_LIMIT:-1}

# Use the internal console since microcom can miss serial input at boot
export LG_CONSOLE=${LG_CONSOLE:-internal}

# Tell u-boot-test-hooks to use the Labgrid-sjg integration
export USE_LABGRID_SJG=${USE_LABGRID_SJG:-1}

# Auto-log labgrid-client output, organised by date and role
export LG_LOG_DIR=${LG_LOG_DIR:-/vid/software/devel/ubtest/labgrid-logs}

export HOSTNAME="$(hostname)"
